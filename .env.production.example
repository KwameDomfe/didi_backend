# Production environment settings template
# Copy this file to .env.production and fill in real values.
# Never commit .env.production to version control.
#
# On hosted platforms (e.g. DigitalOcean App Platform) you can set these
# as platform environment variables instead of using a file — they always
# take precedence over the file anyway.

DJANGO_ENV=production
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key

# Allowed hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-app.ondigitalocean.app

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
USE_POSTGRES=True
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=your-db-host.db.ondigitalocean.com
POSTGRES_PORT=25060

# ── CORS & CSRF ───────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Your App <noreply@yourdomain.com>

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com

# ── Channels / WebSockets ─────────────────────────────────────────────────────
REDIS_URL=redis://your-redis-host:6379

# ── Logging ───────────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO
